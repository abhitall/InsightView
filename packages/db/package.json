{
  "name": "@insightview/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "build": "pnpm generate && tsc -p tsconfig.json",
    "typecheck": "pnpm generate && tsc --noEmit -p tsconfig.json",
    "lint": "echo 'no lint'",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@insightview/core": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
